{
  "name": "rovenue",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=22.7"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "turbo run test",
    "cargo:test": "cargo test --workspace --all-targets",
    "cargo:fmt": "cargo fmt --all -- --check",
    "cargo:clippy": "cargo clippy --workspace --all-targets -- -D warnings",
    "sdk:bindings": "./packages/core-rs/scripts/build-bindings.sh",
    "db:migrate": "pnpm --filter @rovenue/db db:migrate",
    "db:migrate:fresh": "pnpm --filter @rovenue/db db:migrate:fresh",
    "db:migrate:generate": "pnpm --filter @rovenue/db db:migrate:generate",
    "db:seed": "pnpm --filter @rovenue/db seed"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.2.0",
    "turbo": "^2.0.0",
    "typescript": "^5.4.0",
    "typescript-eslint": "^7.0.0"
  },
  "pnpm": {
    "overrides": {
      "vitest": "^3.2.6"
    },
    "auditConfig": {
      "ignoreGhsas": [
        "GHSA-34x7-hfp2-rc4v",
        "GHSA-8qq5-rm4j-mr97",
        "GHSA-83g3-92jg-28cx",
        "GHSA-qffp-2rhf-9h96",
        "GHSA-9ppj-qmqm-q256",
        "GHSA-r6q2-hw4h-h46w",
        "GHSA-wh4c-j3r5-mjhp",
        "GHSA-2v35-w6hq-6mfw",
        "GHSA-f6ww-3ggp-fr8h",
        "GHSA-x6wf-f3px-wcqx",
        "GHSA-j759-j44w-7fr8",
        "GHSA-8x6r-g9mw-2r78",
        "GHSA-rxv8-25v2-qmq8",
        "GHSA-pv5w-4p9q-p3v2",
        "GHSA-96hv-2xvq-fx4p",
        "GHSA-hmw2-7cc7-3qxx",
        "GHSA-fx2h-pf6j-xcff"
      ]
    }
  }
}
