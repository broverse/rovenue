# Copy to `.env.test` and adjust for your local stack. Loaded by
# apps/api/tests/setup.ts BEFORE the hardcoded fallbacks, so you only need
# to list the variables you want to override — unset keys fall through to
# the defaults that match `docker-compose.yml`.
#
# `.env.test` is gitignored. The defaults below already match the compose
# stack, so in most cases you can leave `.env.test` empty or skip it.

DATABASE_URL=postgresql://rovenue:rovenue@localhost:5433/rovenue
REDIS_URL=redis://localhost:6380
KAFKA_BROKERS=localhost:19092
CLICKHOUSE_URL=http://localhost:8124
CLICKHOUSE_USER=rovenue
CLICKHOUSE_PASSWORD=rovenue
