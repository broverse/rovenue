---
const checklist = [
  ['Predictable costs', '— no per-event fees that balloon as you scale.'],
  ['Your data stays yours', '— meet GDPR & KVKK without adding vendors.'],
  ['No lock-in', "— it's open source, so the platform is yours to keep."],
];
---

<section class="lp-section lp-container" id="selfhost">
  <div class="lp-split">
    <div class="lp-chart-card" style="background:var(--content1);align-self:stretch;" data-reveal="up">
      <div class="ch-head"><div><div class="ch-title">Cost as you grow</div><div class="ch-sub">monthly, projected</div></div><span class="chip success">save up to 80%</span></div>
      <svg viewBox="0 0 460 200" preserveAspectRatio="none" style="width:100%;height:180px;display:block;">
        <line x1="0" y1="180" x2="460" y2="180" stroke="var(--divider)" stroke-width="1"/>
        <line x1="0" y1="120" x2="460" y2="120" stroke="var(--divider)" stroke-width="1"/>
        <line x1="0" y1="60" x2="460" y2="60" stroke="var(--divider)" stroke-width="1"/>
        <path d="M0,170 C90,160 150,130 230,92 C300,58 360,30 460,8" fill="none" stroke="var(--danger)" stroke-width="2.5" data-draw/>
        <path d="M0,172 C120,170 240,168 340,166 C400,165 430,164 460,164" fill="none" stroke="var(--accent)" stroke-width="2.5" data-draw/>
        <circle cx="460" cy="8" r="3.5" fill="var(--danger)"/>
        <circle cx="460" cy="164" r="3.5" fill="var(--accent)"/>
      </svg>
      <div class="chart-legend" style="margin-top:10px;">
        <span class="legend-item"><span class="legend-dot" style="background:var(--danger)"></span>Usage-based pricing</span>
        <span class="legend-item"><span class="legend-dot" style="background:var(--accent)"></span>Rovenue self-hosted</span>
      </div>
    </div>
    <div data-reveal="up">
      <div class="lp-kicker">Own your data &amp; your margins</div>
      <h2 class="lp-h2">Grow as big as you want — without the growing bill</h2>
      <p class="lp-lead">Most revenue tools charge more the more you make. Rovenue doesn't. Run it yourself and your costs stay flat while your revenue climbs — and your customer data never leaves your control.</p>
      <ul class="lp-checklist">
        {checklist.map(([bold, rest]) => (
          <li>
            <span class="ck"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg></span>
            <span><b>{bold}</b> {rest}</span>
          </li>
        ))}
      </ul>
    </div>
  </div>
</section>
