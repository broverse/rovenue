---
const platforms = [
  '📱 App Store',
  '🤖 Google Play',
  '🟦 Stripe',
  '⚡ Paddle',
  '🍎 StoreKit 2',
  '🌐 Web checkout',
];
---

<section class="lp-section tight lp-container">
  <div class="lp-sec-head" style="margin-bottom:24px;" data-reveal="up">
    <div class="lp-kicker">Wherever your customers pay</div>
    <h2 class="lp-h2" style="font-size:clamp(24px,2.8vw,32px)">Capture revenue from every store, in one place</h2>
  </div>
  <div class="lp-platforms" data-stagger="60">
    {platforms.map((p) => <span class="lp-plat" data-reveal="up">{p}</span>)}
  </div>
</section>
