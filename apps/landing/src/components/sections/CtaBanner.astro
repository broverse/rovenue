---
import { siteLinks } from '../../config';
---

<section class="lp-section lp-container" id="pricing">
  <div class="lp-cta-banner" data-reveal="scale">
    <h2>Start growing your revenue today</h2>
    <p>Sign up free, point your SDK at Rovenue, and watch your first <code class="inline">purchase_completed</code> land in real time — in minutes, not weeks.</p>
    <div class="lp-cta" style="margin-top:28px;">
      <a class="btn solid-primary glow lg" href={siteLinks.getStarted}>Get started free
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
      </a>
      <a class="btn flat lg" href={siteLinks.github}>
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"/></svg>
        View on GitHub
      </a>
    </div>
  </div>
</section>
