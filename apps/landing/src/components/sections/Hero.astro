---
import { siteLinks } from '../../config';
---

<header class="lp-hero2 lp-container" id="top">
  <div class="lp-hero2-grid">
    <!-- LEFT -->
    <div class="lp-hero2-left" data-stagger="90">
      <span class="lp-eyebrow" data-reveal="up"><span class="dot"></span>Trusted by 1,200+ teams</span>
      <h1 class="lp-h1" data-reveal="up">Turn subscribers into <span class="grad">growing revenue</span></h1>
      <p class="lp-sub" data-reveal="up">Rovenue shows you what's driving revenue, helps you test what grows it, and keeps more customers from churning — so your team spends less time in spreadsheets and more time growing the business.</p>

      <div class="lp-auth2" data-reveal="up">
        <a class="lp-auth-btn primary" href={siteLinks.getStarted}>
          <svg width="18" height="18" viewBox="0 0 48 48" aria-hidden="true"><path fill="#FFC107" d="M43.6 20.5H42V20H24v8h11.3C33.7 32.9 29.3 36 24 36c-6.6 0-12-5.4-12-12s5.4-12 12-12c3.1 0 5.9 1.2 8 3.1l5.7-5.7C34.5 6.5 29.5 4.5 24 4.5 13.2 4.5 4.5 13.2 4.5 24S13.2 43.5 24 43.5 43.5 34.8 43.5 24c0-1.2-.1-2.4-.4-3.5z"/><path fill="#FF3D00" d="M6.3 14.7l6.6 4.8C14.7 15.1 19 12 24 12c3.1 0 5.9 1.2 8 3.1l5.7-5.7C34.5 6.5 29.5 4.5 24 4.5 16.3 4.5 9.7 8.9 6.3 14.7z"/><path fill="#4CAF50" d="M24 43.5c5.4 0 10.3-2 13.9-5.3l-6.4-5.4C29.4 34.4 26.8 35.5 24 35.5c-5.3 0-9.7-3.1-11.3-7.4l-6.6 5.1C9.6 39.1 16.2 43.5 24 43.5z"/><path fill="#1976D2" d="M43.6 20.5H42V20H24v8h11.3c-.8 2.2-2.2 4.1-4 5.4l6.4 5.4c-.5.4 6.8-4.9 6.8-14.8 0-1.2-.1-2.4-.4-3.5z"/></svg>
          Continue with Google
        </a>
        <div class="lp-auth2-row">
          <a class="lp-auth-btn" href={siteLinks.getStarted}>
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 1.5C6.2 1.5 1.5 6.2 1.5 12c0 4.6 3 8.6 7.2 9.9.5.1.7-.2.7-.5v-1.9c-2.9.6-3.6-1.2-3.6-1.2-.5-1.2-1.2-1.6-1.2-1.6-1-.6.1-.6.1-.6 1 .1 1.6 1 1.6 1 .9 1.6 2.4 1.1 3 .9.1-.7.4-1.1.7-1.4-2.3-.3-4.8-1.2-4.8-5.2 0-1.1.4-2.1 1-2.9-.1-.3-.5-1.3.1-2.8 0 0 .9-.3 2.8 1.1.8-.2 1.7-.3 2.6-.3.9 0 1.8.1 2.6.3 1.9-1.3 2.8-1.1 2.8-1.1.6 1.5.2 2.5.1 2.8.7.8 1 1.8 1 2.9 0 4.1-2.5 4.9-4.8 5.2.4.3.7 1 .7 2v3c0 .3.2.6.7.5 4.2-1.4 7.2-5.3 7.2-9.9C22.5 6.2 17.8 1.5 12 1.5z"/></svg>
            GitHub
          </a>
          <a class="lp-auth-btn" href={siteLinks.signIn}>
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
            Email
          </a>
        </div>
        <div class="lp-auth2-foot">
          <span>No credit card.</span>
          <span class="sh-line"></span>
          <a class="lp-selfhost-link" href="#selfhost"><span class="pr">$</span> self-host it free</a>
        </div>
      </div>

      <div class="lp-trust" data-reveal="up">
        <div class="lp-trust-avatars">
          <span style="background:linear-gradient(135deg,#3B82F6,#1D4ED8)">P</span>
          <span style="background:linear-gradient(135deg,#8B5CF6,#6D28D9)">N</span>
          <span style="background:linear-gradient(135deg,#10B981,#047857)">S</span>
          <span style="background:linear-gradient(135deg,#F59E0B,#B45309)">K</span>
        </div>
        <div class="lp-trust-text"><span class="stars">★★★★★</span><br>Loved by <b>1,200+</b> teams growing on Rovenue</div>
      </div>
    </div>

    <!-- RIGHT: floating composition -->
    <div class="lp-stage">
      <div class="lp-panel" data-reveal="scale">
        <div class="lp-panel-inner">
          <div class="lp-panel-head">
            <span class="pa">R</span>
            <div><div class="pt">Revenue overview</div><div class="ps">posely · live</div></div>
            <span class="live-chip"><span class="pulse"></span>Live</span>
          </div>
          <div class="lp-panel-body">
            <div class="lp-panel-hero-stat">
              <span class="big cu" data-to="148920" data-prefix="$" data-sep="1">$0</span>
              <span class="delta">▲ 12.4%</span>
            </div>
            <div class="lp-panel-hero-stat" style="margin-top:2px;"><span class="lab">Annual recurring revenue</span></div>
            <div class="lp-panel-spark">
              <svg viewBox="0 0 420 110" preserveAspectRatio="none" style="width:100%;height:96px;display:block;">
                <defs>
                  <linearGradient id="heroArea" x1="0" y1="0" x2="0" y2="1">
                    <stop offset="0%" stop-color="var(--accent)" stop-opacity="0.32"/>
                    <stop offset="100%" stop-color="var(--accent)" stop-opacity="0"/>
                  </linearGradient>
                </defs>
                <path d="M0,88 C40,82 70,74 110,72 C150,70 175,80 210,62 C250,42 275,48 315,32 C355,18 380,18 420,8 L420,110 L0,110 Z" fill="url(#heroArea)"/>
                <path id="heroSpark" d="M0,88 C40,82 70,74 110,72 C150,70 175,80 210,62 C250,42 275,48 315,32 C355,18 380,18 420,8" fill="none" stroke="var(--accent)" stroke-width="2"/>
                <circle id="heroSparkDot" cx="420" cy="8" r="3.5" fill="var(--accent)"/>
              </svg>
            </div>
            <div class="lp-panel-foot">
              <div><div class="l">Subscribers</div><div class="v cu" data-to="2431" data-sep="1">0</div></div>
              <div><div class="l">Trial → paid</div><div class="v cu" data-to="42.8" data-dec="1" data-suffix="%">0%</div></div>
              <div><div class="l">Net churn</div><div class="v cu" data-to="-3.2" data-dec="1" data-suffix="%">0%</div></div>
            </div>
          </div>
        </div>
      </div>

      <!-- floating: live subscriber (rotates) -->
      <div class="lp-float lp-float-event" id="floatEvent" data-reveal="fade">
        <span class="ic" id="floatEventIc"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg></span>
        <div><div class="nm" id="floatEventNm">New subscriber</div><div class="mt" id="floatEventMt">Pro Annual · iOS · now</div></div>
        <span class="amt" id="floatEventAmt">+$59.99</span>
      </div>

      <!-- floating: retention -->
      <div class="lp-float lp-float-churn" data-reveal="fade">
        <div class="l">Retention</div>
        <div class="row"><span class="v cu" data-to="94.6" data-dec="1" data-suffix="%">0%</span><span class="d">▲ 2.1pp</span></div>
        <div class="mini">
          <i data-bar="h" style="--bar:60%"></i><i data-bar="h" style="--bar:72%"></i><i data-bar="h" style="--bar:66%"></i><i data-bar="h" style="--bar:84%"></i><i data-bar="h" style="--bar:78%"></i><i class="hot" data-bar="h" style="--bar:100%"></i>
        </div>
      </div>
    </div>
  </div>
</header>

<script>
  // ---- hero: count-up numbers (time-based, with guaranteed final value) ----
  (function () {
    const els = [...document.querySelectorAll<HTMLElement>('.cu')];
    if (!els.length) return;
    const fmt = (n: number, dec: number, sep?: string) => {
      let s = n.toFixed(dec);
      if (sep === '1') {
        const [i, d] = s.split('.');
        s = i.replace(/\B(?=(\d{3})+(?!\d))/g, ',') + (d ? '.' + d : '');
      }
      return s;
    };
    const render = (el: HTMLElement, n: number) => {
      const dec = +(el.dataset.dec || 0), sep = el.dataset.sep, pre = el.dataset.prefix || '', suf = el.dataset.suffix || '';
      el.textContent = pre + fmt(n, dec, sep) + suf;
    };
    const targets = new WeakMap<HTMLElement, number>();
    const run = () => {
      const dur = 1300, start = performance.now();
      els.forEach((el) => targets.set(el, parseFloat(el.dataset.to || '0')));
      const tick = (now: number) => {
        const t = Math.min(1, (now - start) / dur);
        const e = 1 - Math.pow(1 - t, 3); // easeOutCubic
        els.forEach((el) => render(el, (targets.get(el) || 0) * e));
        if (t < 1) requestAnimationFrame(tick);
        else els.forEach((el) => render(el, targets.get(el) || 0));
      };
      requestAnimationFrame(tick);
      // safety: ensure finals even if rAF is throttled
      setTimeout(() => els.forEach((el) => render(el, targets.get(el) || 0)), dur + 250);
    };
    run();
  })();

  // ---- hero: draw-on sparkline ----
  (function () {
    const path = document.getElementById('heroSpark') as unknown as SVGPathElement | null;
    if (!path || !path.getTotalLength) return;
    try {
      const len = path.getTotalLength();
      path.style.strokeDasharray = String(len);
      path.style.strokeDashoffset = String(len);
      const dur = 1400, start = performance.now();
      const tick = (now: number) => {
        const t = Math.min(1, (now - start) / dur);
        const e = 1 - Math.pow(1 - t, 3);
        path.style.strokeDashoffset = (len * (1 - e)).toFixed(1);
        if (t < 1) requestAnimationFrame(tick);
        else path.style.strokeDashoffset = '0';
      };
      requestAnimationFrame(tick);
      setTimeout(() => { path.style.strokeDashoffset = '0'; }, dur + 250);
    } catch (e) { path.style.strokeDashoffset = '0'; }
  })();

  // ---- hero: rotating live-event card ----
  (function () {
    const card = document.getElementById('floatEvent');
    const nm = document.getElementById('floatEventNm');
    const mt = document.getElementById('floatEventMt');
    const amt = document.getElementById('floatEventAmt');
    const ic = document.getElementById('floatEventIc');
    if (!card || !nm || !mt || !amt || !ic) return;
    const events = [
      { nm: 'New subscriber', mt: 'Pro Annual · iOS · now', amt: '+$59.99', color: 'var(--success)' },
      { nm: 'Subscription renewed', mt: 'Pro Monthly · Android · now', amt: '+$9.99', color: 'var(--accent)' },
      { nm: 'Trial started', mt: 'Pro Annual · web · now', amt: '—', color: 'var(--warning)' },
      { nm: 'Upgrade', mt: 'Monthly → Annual · iOS', amt: '+$50.00', color: 'var(--violet)' },
    ];
    let i = 0;
    setInterval(() => {
      i = (i + 1) % events.length;
      const ev = events[i];
      card.classList.add('swapping');
      setTimeout(() => {
        nm.textContent = ev.nm; mt.textContent = ev.mt; amt.textContent = ev.amt;
        amt.style.color = ev.amt === '—' ? 'var(--default-500)' : 'var(--success)';
        ic.style.background = `color-mix(in srgb, ${ev.color} 16%, transparent)`;
        ic.style.color = ev.color;
        card.classList.remove('swapping');
      }, 320);
    }, 2900);
  })();
</script>
