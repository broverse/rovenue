<?xml version="1.0"?>
<!--
  Two users: `rovenue` owns the schema and is used by the migration
  runner + PeerDB target; `rovenue_reader` is read-only and is what
  the API's analytics-router uses for dashboard queries. The default
  user is disabled so nothing runs without explicit credentials.

  readonly must be expressed as a profile setting, not a per-user
  field — the per-user <readonly> tag is silently ignored. We define
  a `readonly_analytics` profile with readonly=2 (SELECT + SHOW only,
  settings changes blocked from the client side but allowed from
  profile) and apply it to rovenue_reader.
-->
<clickhouse>
  <profiles>
    <readonly_analytics>
      <readonly>2</readonly>
      <!-- Block memory/binary introspection functions (addressToLine,
           symbolizeTrace, …) for the query-playground reader. -->
      <allow_introspection_functions>0</allow_introspection_functions>
      <constraints>
        <readonly>
          <readonly/>
        </readonly>
        <allow_introspection_functions>
          <readonly/>
        </allow_introspection_functions>
      </constraints>
    </readonly_analytics>
  </profiles>
  <!--
    Defense-in-depth note: ClickHouse table functions (url/file/remote/merge/
    s3/mysql/…) read data OUTSIDE the `rovenue` database, so neither readonly=2
    nor the <databases> allow-list stops them — they can reach internal
    services, the cloud-metadata endpoint, or the local filesystem. The API's
    query playground rejects those functions before execution
    (validatePlaygroundSql in apps/api/src/services/queries-playground.ts).
    Operators SHOULD additionally deny this container outbound network egress
    (except to its own dependencies) so a future gap in the app-layer filter
    cannot be turned into SSRF.
  -->

  <users>
    <default remove="remove"/>
    <rovenue>
      <password_sha256_hex from_env="CLICKHOUSE_PASSWORD_SHA256"/>
      <networks>
        <!-- Docker Compose default bridge network (172.17.0.0/16) falls
             within 172.16.0.0/12; 10.0.0.0/8 covers custom bridge /
             overlay networks. Localhost is kept for local healthchecks. -->
        <ip>127.0.0.1</ip>
        <ip>::1</ip>
        <ip>172.16.0.0/12</ip>
        <ip>10.0.0.0/8</ip>
      </networks>
      <profile>default</profile>
      <quota>default</quota>
      <access_management>0</access_management>
      <named_collection_control>0</named_collection_control>
      <databases>
        <rovenue/>
      </databases>
    </rovenue>
    <rovenue_reader>
      <password_sha256_hex from_env="CLICKHOUSE_READER_PASSWORD_SHA256"/>
      <networks>
        <ip>127.0.0.1</ip>
        <ip>::1</ip>
        <ip>172.16.0.0/12</ip>
        <ip>10.0.0.0/8</ip>
      </networks>
      <profile>readonly_analytics</profile>
      <quota>default</quota>
      <databases>
        <rovenue/>
      </databases>
    </rovenue_reader>
  </users>
</clickhouse>
