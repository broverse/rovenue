# =============================================================
# Rovenue edge — Caddy 2.x
# =============================================================
#
# Two terminate-and-proxy scopes:
#
#   1. Canonical surface — *.rovenue.io, rovenue.io, edge.rovenue.io
#      → automatic HTTPS via standard ACME (no on-demand). The
#      hostnames are known up front so Caddy can solicit certs at
#      startup and renew on the normal schedule.
#
#   2. Custom domains — any other hostname that arrives. Caddy uses
#      on-demand TLS, but ONLY after asking the api at
#      `internal:3001/internal/domains/check?domain={host}`. That
#      endpoint returns 200 only for verified custom_domains rows
#      and the canonical hostnames above, so an attacker spraying
#      random hostnames can't trip Let's Encrypt rate limits.
#
# Operator notes:
#   - Set the operator email via $TLS_EMAIL (used for ACME account).
#   - The ACME state volume (/data) MUST persist across deploys, or
#     every redeploy re-issues every cert (rate-limit risk).
#   - `internal:3001` is the docker-network DNS name for the api
#     service's internal listener. The compose file does NOT publish
#     port 3001 — only Caddy can reach it.

{
    email {$TLS_EMAIL:ops@rovenue.io}

    # Gate on-demand cert issuance through the api's ask-endpoint.
    on_demand_tls {
        ask http://api:3001/internal/domains/check
        # Throttle issuance even when the ask passes — defence in
        # depth in case the ask-endpoint is misconfigured.
        interval 2m
        burst 5
    }
}

# -------------------------------------------------------------
# Dashboard SPA — explicit host, proxied to the static-serving
# dashboard container. Must precede the *.rovenue.io wildcard
# (which targets the api); most-specific host wins in Caddy.
# -------------------------------------------------------------
app.rovenue.io {
	encode zstd gzip
	reverse_proxy dashboard:80
}

# -------------------------------------------------------------
# Docs site — explicit host, proxied to the static-serving docs
# container. Must precede the *.rovenue.io wildcard.
# -------------------------------------------------------------
docs.rovenue.io {
	encode zstd gzip
	reverse_proxy docs:80
}

# -------------------------------------------------------------
# Canonical surface — explicit cert via standard ACME.
# -------------------------------------------------------------
rovenue.io, *.rovenue.io, edge.rovenue.io {
    encode zstd gzip
    reverse_proxy api:3000 {
        header_up X-Forwarded-Host {host}
        header_up X-Forwarded-Proto {scheme}
        header_up X-Real-IP {remote_host}
    }
}

# -------------------------------------------------------------
# Custom domains — on-demand TLS, gated by the ask-endpoint.
#
# This block matches every host NOT covered above. Caddy will only
# attempt cert issuance when the ask-endpoint says yes; otherwise
# it returns a generic TLS error to the client (no cert, no serve).
# -------------------------------------------------------------
:443 {
    tls {
        on_demand
    }
    encode zstd gzip
    reverse_proxy api:3000 {
        header_up X-Forwarded-Host {host}
        header_up X-Forwarded-Proto {scheme}
        header_up X-Real-IP {remote_host}
    }
}

# -------------------------------------------------------------
# Port 80 — redirect everything to HTTPS. Caddy's auto-redirect
# handles canonical names; this block covers the on-demand case.
# -------------------------------------------------------------
:80 {
    redir https://{host}{uri} permanent
}
