{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "emitDeclarationOnly": true,
    "declaration": true,
    "declarationMap": true,
    "noImplicitAny": false,
    "outDir": "./dist",
    "rootDir": "./src"
  },
  "include": ["src/index.ts", "src/version.ts"],
  "exclude": [
    "dist",
    "node_modules",
    "plugin",
    "src/__tests__",
    "**/*.test.ts",
    "**/*.test.tsx"
  ]
}
