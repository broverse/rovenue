generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =============================================================
// Better Auth models
// Regenerate with: npx @better-auth/cli generate --adapter prisma
// =============================================================

model User {
  id            String    @id
  name          String
  email         String    @unique
  emailVerified Boolean
  image         String?
  createdAt     DateTime
  updatedAt     DateTime
  sessions      Session[]
  accounts      Account[]
  members       ProjectMember[]
  auditLogs     AuditLog[]

  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime
  updatedAt DateTime
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime
  updatedAt             DateTime
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("account")
}

model Verification {
  id         String    @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime?
  updatedAt  DateTime?

  @@map("verification")
}

// =============================================================
// Auth & project
// =============================================================

enum MemberRole {
  OWNER
  ADMIN
  VIEWER
}

enum Environment {
  PRODUCTION
  SANDBOX
}

model ProjectMember {
  id        String     @id @default(cuid(2))
  projectId String
  userId    String
  role      MemberRole
  createdAt DateTime   @default(now()) @db.Timestamptz
  updatedAt DateTime   @updatedAt @db.Timestamptz

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@index([userId])
  @@map("project_members")
}

model ApiKey {
  id            String      @id @default(cuid(2))
  projectId     String
  label         String
  keyPublic     String      @unique
  keySecretHash String
  lastUsedAt    DateTime?   @db.Timestamptz
  expiresAt     DateTime?   @db.Timestamptz
  revokedAt     DateTime?   @db.Timestamptz
  environment   Environment
  createdAt     DateTime    @default(now()) @db.Timestamptz
  updatedAt     DateTime    @updatedAt @db.Timestamptz

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@map("api_keys")
}

model Project {
  id                String   @id @default(cuid(2))
  name              String
  slug              String   @unique
  appleCredentials  Json?
  googleCredentials Json?
  stripeCredentials Json?
  webhookUrl        String?
  webhookSecret     String?
  settings          Json     @default("{}")
  createdAt         DateTime @default(now()) @db.Timestamptz
  updatedAt         DateTime @updatedAt @db.Timestamptz

  members          ProjectMember[]
  apiKeys          ApiKey[]
  products         Product[]
  productGroups    ProductGroup[]
  subscribers      Subscriber[]
  purchases        Purchase[]
  creditLedger     CreditLedger[]
  webhookEvents    WebhookEvent[]
  outgoingWebhooks OutgoingWebhook[]
  revenueEvents    RevenueEvent[]
  audiences        Audience[]
  experiments      Experiment[]
  featureFlags     FeatureFlag[]
  auditLogs        AuditLog[]

  @@map("projects")
}

// =============================================================
// Catalog — Product (ne) / ProductGroup (nasıl)
// =============================================================

enum ProductType {
  SUBSCRIPTION
  CONSUMABLE
  NON_CONSUMABLE
}

model Product {
  id              String      @id @default(cuid(2))
  projectId       String
  identifier      String
  type            ProductType
  storeIds        Json
  displayName     String
  entitlementKeys String[]
  creditAmount    Int?
  isActive        Boolean     @default(true)
  metadata        Json        @default("{}")
  createdAt       DateTime    @default(now()) @db.Timestamptz
  updatedAt       DateTime    @updatedAt @db.Timestamptz

  project       Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  purchases     Purchase[]
  revenueEvents RevenueEvent[]

  @@unique([projectId, identifier])
  @@index([projectId, isActive])
  @@map("products")
}

model ProductGroup {
  id         String   @id @default(cuid(2))
  projectId  String
  identifier String
  isDefault  Boolean  @default(false)
  products   Json     @default("[]")
  metadata   Json     @default("{}")
  createdAt  DateTime @default(now()) @db.Timestamptz
  updatedAt  DateTime @updatedAt @db.Timestamptz

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, identifier])
  @@index([projectId, isDefault])
  @@map("product_groups")
}

// =============================================================
// Subscribers
// =============================================================

model Subscriber {
  id          String    @id @default(cuid(2))
  projectId   String
  appUserId   String
  firstSeenAt DateTime  @default(now()) @db.Timestamptz
  lastSeenAt  DateTime  @default(now()) @db.Timestamptz
  attributes  Json      @default("{}")
  deletedAt   DateTime? @db.Timestamptz
  mergedInto  String?
  createdAt   DateTime  @default(now()) @db.Timestamptz
  updatedAt   DateTime  @updatedAt @db.Timestamptz

  project                Project                 @relation(fields: [projectId], references: [id], onDelete: Cascade)
  purchases              Purchase[]
  access                 SubscriberAccess[]
  creditLedger           CreditLedger[]
  revenueEvents          RevenueEvent[]
  webhookEvents          WebhookEvent[]
  outgoingWebhooks       OutgoingWebhook[]
  experimentAssignments  ExperimentAssignment[]

  @@unique([projectId, appUserId])
  @@map("subscribers")
}

enum Store {
  APP_STORE
  PLAY_STORE
  STRIPE
}

enum PurchaseStatus {
  TRIAL
  ACTIVE
  EXPIRED
  REFUNDED
  REVOKED
  PAUSED
  GRACE_PERIOD
}

model Purchase {
  id                    String         @id @default(cuid(2))
  projectId             String
  subscriberId          String
  productId             String
  store                 Store
  storeTransactionId    String
  originalTransactionId String
  status                PurchaseStatus
  isTrial               Boolean        @default(false)
  isIntroOffer          Boolean        @default(false)
  isSandbox             Boolean        @default(false)
  purchaseDate          DateTime       @db.Timestamptz
  expiresDate           DateTime?      @db.Timestamptz
  originalPurchaseDate  DateTime       @db.Timestamptz
  priceAmount           Decimal?       @db.Decimal(12, 4)
  priceCurrency         String?
  environment           Environment
  autoRenewStatus       Boolean?
  cancellationDate      DateTime?      @db.Timestamptz
  refundDate            DateTime?      @db.Timestamptz
  gracePeriodExpires    DateTime?      @db.Timestamptz
  ownershipType         String?
  verifiedAt            DateTime?      @db.Timestamptz
  createdAt             DateTime       @default(now()) @db.Timestamptz
  updatedAt             DateTime       @updatedAt @db.Timestamptz

  project          Project            @relation(fields: [projectId], references: [id], onDelete: Cascade)
  subscriber       Subscriber         @relation(fields: [subscriberId], references: [id], onDelete: Cascade)
  product          Product            @relation(fields: [productId], references: [id])
  access           SubscriberAccess[]
  revenueEvents    RevenueEvent[]
  webhookEvents    WebhookEvent[]
  outgoingWebhooks OutgoingWebhook[]

  @@unique([store, storeTransactionId])
  @@index([originalTransactionId])
  @@index([subscriberId, status])
  @@index([expiresDate])
  @@map("purchases")
}

model SubscriberAccess {
  id             String    @id @default(cuid(2))
  subscriberId   String
  purchaseId     String
  entitlementKey String
  isActive       Boolean   @default(true)
  expiresDate    DateTime? @db.Timestamptz
  store          Store
  createdAt      DateTime  @default(now()) @db.Timestamptz
  updatedAt      DateTime  @updatedAt @db.Timestamptz

  subscriber Subscriber @relation(fields: [subscriberId], references: [id], onDelete: Cascade)
  purchase   Purchase   @relation(fields: [purchaseId], references: [id], onDelete: Cascade)

  @@index([subscriberId, isActive])
  @@index([subscriberId, entitlementKey])
  @@map("subscriber_access")
}

// =============================================================
// Credits (append-only ledger)
// =============================================================

enum CreditLedgerType {
  PURCHASE
  SPEND
  REFUND
  BONUS
  EXPIRE
  TRANSFER_IN
  TRANSFER_OUT
}

model CreditLedger {
  id            String           @id @default(cuid(2))
  projectId     String
  subscriberId  String
  type          CreditLedgerType
  amount        Int
  balance       Int
  referenceType String?
  referenceId   String?
  description   String?
  metadata      Json?
  createdAt     DateTime         @default(now()) @db.Timestamptz

  project    Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  subscriber Subscriber @relation(fields: [subscriberId], references: [id], onDelete: Cascade)

  @@index([subscriberId, createdAt])
  @@index([projectId, subscriberId])
  @@map("credit_ledger")
}

// =============================================================
// Events
// =============================================================

enum WebhookSource {
  APPLE
  GOOGLE
  STRIPE
}

enum WebhookEventStatus {
  RECEIVED
  PROCESSING
  PROCESSED
  FAILED
}

model WebhookEvent {
  id           String             @id @default(cuid(2))
  projectId    String
  source       WebhookSource
  eventType    String
  storeEventId String
  payload      Json
  status       WebhookEventStatus @default(RECEIVED)
  subscriberId String?
  purchaseId   String?
  errorMessage String?
  processedAt  DateTime?          @db.Timestamptz
  retryCount   Int                @default(0)
  createdAt    DateTime           @default(now()) @db.Timestamptz

  project    Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  subscriber Subscriber? @relation(fields: [subscriberId], references: [id])
  purchase   Purchase?   @relation(fields: [purchaseId], references: [id])

  @@unique([source, storeEventId])
  @@index([status, retryCount])
  @@map("webhook_events")
}

enum OutgoingWebhookStatus {
  PENDING
  SENT
  FAILED
  DEAD
  DISMISSED
}

model OutgoingWebhook {
  id               String                @id @default(cuid(2))
  projectId        String
  eventType        String
  subscriberId     String
  purchaseId       String?
  payload          Json
  url              String
  status           OutgoingWebhookStatus @default(PENDING)
  httpStatus       Int?
  responseBody     String?
  lastErrorMessage String?
  attempts         Int                   @default(0)
  nextRetryAt      DateTime?             @db.Timestamptz
  sentAt           DateTime?             @db.Timestamptz
  deadAt           DateTime?             @db.Timestamptz
  createdAt        DateTime              @default(now()) @db.Timestamptz

  project    Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  subscriber Subscriber @relation(fields: [subscriberId], references: [id], onDelete: Cascade)
  purchase   Purchase?  @relation(fields: [purchaseId], references: [id])

  @@index([status, nextRetryAt])
  @@index([projectId, status])
  @@map("outgoing_webhooks")
}

enum RevenueEventType {
  INITIAL
  RENEWAL
  TRIAL_CONVERSION
  CANCELLATION
  REFUND
  REACTIVATION
  CREDIT_PURCHASE
}

model RevenueEvent {
  id           String           @id @default(cuid(2))
  projectId    String
  subscriberId String
  purchaseId   String
  type         RevenueEventType
  amount       Decimal          @db.Decimal(12, 4)
  currency     String
  amountUsd    Decimal          @db.Decimal(12, 4)
  store        Store
  productId    String
  eventDate    DateTime         @db.Timestamptz
  createdAt    DateTime         @default(now()) @db.Timestamptz

  project    Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  subscriber Subscriber @relation(fields: [subscriberId], references: [id], onDelete: Cascade)
  purchase   Purchase   @relation(fields: [purchaseId], references: [id])
  product    Product    @relation(fields: [productId], references: [id])

  @@index([projectId, eventDate])
  @@index([subscriberId, type])
  @@map("revenue_events")
}

// =============================================================
// Experiment engine — Audiences, Experiments, Assignments, Flags
// =============================================================

/// Targeting group evaluated via sift / MongoDB-style queries.
/// `rules` is a JSON document matched against the subscriber's
/// runtime attributes: { country: { $in: ["TR"] }, appVersion: { $gte: "2.0" } }
/// An empty object (`{}`) matches every subscriber — that's the
/// canonical "All Users" audience flagged with `isDefault = true`.
model Audience {
  id          String   @id @default(cuid(2))
  projectId   String
  name        String
  description String?
  rules       Json     @default("{}")
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now()) @db.Timestamptz
  updatedAt   DateTime @updatedAt @db.Timestamptz

  project     Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  experiments Experiment[]

  @@unique([projectId, name])
  @@index([projectId])
  @@map("audiences")
}

enum ExperimentType {
  FLAG
  PRODUCT_GROUP
  PAYWALL
  ELEMENT
}

enum ExperimentStatus {
  DRAFT
  RUNNING
  PAUSED
  COMPLETED
}

/// A single experiment definition. Variant values are stored as
/// opaque JSON — the engine never introspects them. Type-specific
/// shape (PaywallConfig, flag value, product group key, etc.)
/// is validated against @rovenue/shared schemas at the API layer
/// and cast at the SDK boundary via generics.
///
/// `mutualExclusionGroup` lets two experiments share a namespace
/// so a subscriber can only land in one of them — prevents
/// interaction effects between overlapping paywall tests.
model Experiment {
  id                   String            @id @default(cuid(2))
  projectId            String
  name                 String
  description          String?
  type                 ExperimentType
  key                  String
  audienceId           String
  status               ExperimentStatus  @default(DRAFT)
  variants             Json
  metrics              Json?
  mutualExclusionGroup String?
  startedAt            DateTime?         @db.Timestamptz
  completedAt          DateTime?         @db.Timestamptz
  winnerVariantId      String?
  createdAt            DateTime          @default(now()) @db.Timestamptz
  updatedAt            DateTime          @updatedAt @db.Timestamptz

  project     Project                @relation(fields: [projectId], references: [id], onDelete: Cascade)
  audience    Audience               @relation(fields: [audienceId], references: [id])
  assignments ExperimentAssignment[]

  @@unique([projectId, key])
  @@index([projectId, status])
  @@index([mutualExclusionGroup])
  @@map("experiments")
}

/// Per-subscriber assignment + append-only funnel log.
/// `events` records every step in the funnel (paywall_viewed,
/// cta_clicked, purchase, …) so conversion analysis can compute
/// funnel drop-off per variant without joining across tables.
/// `convertedAt` is set when the first revenue event is logged;
/// the unique index on (experimentId, subscriberId) guarantees a
/// subscriber only lands in the same variant on repeat visits.
model ExperimentAssignment {
  id           String    @id @default(cuid(2))
  experimentId String
  subscriberId String
  variantId    String
  assignedAt   DateTime  @default(now()) @db.Timestamptz
  events       Json      @default("[]")
  convertedAt  DateTime? @db.Timestamptz
  purchaseId   String?
  revenue      Decimal?  @db.Decimal(12, 4)
  createdAt    DateTime  @default(now()) @db.Timestamptz
  updatedAt    DateTime  @updatedAt @db.Timestamptz

  experiment Experiment @relation(fields: [experimentId], references: [id], onDelete: Cascade)
  subscriber Subscriber @relation(fields: [subscriberId], references: [id], onDelete: Cascade)

  @@unique([experimentId, subscriberId])
  @@index([subscriberId])
  @@index([experimentId, convertedAt])
  @@map("experiment_assignments")
}

enum FeatureFlagType {
  BOOLEAN
  STRING
  NUMBER
  JSON
}

/// Standalone feature flag (not tied to an experiment). Rules are
/// evaluated in order and the first audience match wins. Each rule
/// may carry an optional `rolloutPercentage` (0..1) that the engine
/// resolves with a murmurhash bucket against the subscriber id.
///
/// Evaluation order:
///   1. isEnabled = false           → defaultValue (kill switch)
///   2. rules[i].audience matches   → rules[i].value
///      (subject to rolloutPercentage bucketing)
///   3. no rule matches             → defaultValue
model FeatureFlag {
  id           String          @id @default(cuid(2))
  projectId    String
  key          String
  type         FeatureFlagType
  defaultValue Json
  rules        Json            @default("[]")
  isEnabled    Boolean         @default(true)
  description  String?
  createdAt    DateTime        @default(now()) @db.Timestamptz
  updatedAt    DateTime        @updatedAt @db.Timestamptz

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, key])
  @@index([projectId, isEnabled])
  @@map("feature_flags")
}

// =============================================================
// Audit log — immutable history of dashboard mutations
// =============================================================

/// Immutable, tamper-evident mutation log. Every row carries a
/// SHA-256 `rowHash` computed over `(prevHash || canonical_payload)`,
/// where `prevHash` points at the previous row in the same project's
/// chain. A missing or broken link is verifiable evidence of
/// rewritten history.
///
/// `prevHash` is nullable only for the first row in a project's
/// chain. `rowHash` is always set by the application writer — the
/// DB column stays nullable only because Postgres can't retroactively
/// enforce NOT NULL on rows that predate the chain.
///
/// UPDATE and DELETE are blocked at the DB level via triggers so a
/// compromised application account can't silently rewrite history.
model AuditLog {
  id         String   @id @default(cuid(2))
  projectId  String
  userId     String
  action     String
  resource   String
  resourceId String
  before     Json?
  after      Json?
  ipAddress  String?
  userAgent  String?
  prevHash   String?
  rowHash    String?  @unique
  createdAt  DateTime @default(now()) @db.Timestamptz

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([projectId, createdAt])
  @@index([action])
  @@index([resourceId])
  @@index([userId])
  @@map("audit_logs")
}
