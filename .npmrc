engine-strict=true
strict-peer-dependencies=false
auto-install-peers=true
# Expo/Metro in a pnpm monorepo needs a flat, npm-style node_modules so
# Metro can resolve Expo's transitive deps (expo-asset, @babel/runtime,
# @expo/metro-runtime, …) from the project/workspace node_modules. The
# default isolated linker hides them in the .pnpm store. This is the
# Expo-recommended setting for pnpm monorepos.
node-linker=hoisted
link-workspace-packages=true
prefer-workspace-packages=true
