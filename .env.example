# =========================================================================
# Rovenue environment variables — copy to .env and fill in real secrets.
# =========================================================================

# ---- Server ------------------------------------------------------------
PORT=3000
NODE_ENV=development
LOG_LEVEL=debug

# Number of trusted reverse proxies in front of the API (Coolify/Caddy = 1).
# Used to pick the real client IP from X-Forwarded-For for rate limiting.
TRUSTED_PROXY_COUNT=1

# ---- Internal listener (Caddy on-demand-TLS ask endpoint) --------------
# Bound to a SEPARATE port that's NEVER published in docker-compose
# `ports:` — only Caddy on the same docker network can reach it. Keep
# the default unless you're running multiple stacks on one host.
INTERNAL_PORT=3001

# ---- Deployment mode ---------------------------------------------------
# "self"  = self-hosted single tenant: no billing, Rovi unlimited + BYOK,
#           registration closed after the first user (invite-only).
# "cloud" = managed cloud: Stripe billing, Rovi tier quotas, open signup.
HOST_MODE=self
# Override open-registration. Unset = derived from HOST_MODE
# (self -> false, cloud -> true). "true" lets anyone sign up.
# ALLOW_REGISTRATION=

# Hostnames the canonical edge serves directly (skips the custom-domain
# lookup). Comma-separated, lowercased. The on-demand-TLS ask endpoint
# returns 200 for these even when no custom_domains row exists.
CANONICAL_HOSTS=rovenue.io,edge.rovenue.io

# Operator email used by Caddy to register the Let's Encrypt account.
# Required in production; defaults to ops@rovenue.io otherwise.
TLS_EMAIL=ops@rovenue.io

# ---- Postgres (consumed by the `db` service in docker-compose) ---------
POSTGRES_USER=rovenue
POSTGRES_PASSWORD=rovenue
POSTGRES_DB=rovenue

# ---- Database / cache URLs ---------------------------------------------
# For local dev outside Docker, point these at localhost. When running
# via `docker compose up`, compose overrides them to reach the db/redis
# services by their in-network hostnames.
DATABASE_URL=postgresql://rovenue:rovenue@localhost:5433/rovenue
REDIS_URL=redis://localhost:6380

# ---- ClickHouse (analytics read replica) -------------------------------
# Populated by PeerDB from Postgres. Leave blank in local dev if the
# clickhouse service isn't booted; analytics-router degrades to "no
# data" responses. Required in production.
CLICKHOUSE_URL=http://localhost:8124
CLICKHOUSE_USER=rovenue_reader
CLICKHOUSE_PASSWORD=rovenue

# ---- Encryption --------------------------------------------------------
# 32-byte hex for AES-256-GCM on stored store credentials.
ENCRYPTION_KEY=

# ---- Better Auth -------------------------------------------------------
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000
DASHBOARD_URL=http://localhost:5173
# Production: DASHBOARD_URL=https://app.rovenue.io
# Public origin of the API. Must match the OAuth redirect URI registered
# with Stripe exactly: <PUBLIC_BASE_URL>/stripe/oauth/callback
PUBLIC_BASE_URL=http://localhost:3000

# Public origin the dashboard SPA calls (baked into the bundle at
# docker build time). In production this is the api's public URL.
VITE_API_URL=http://localhost:3000

# ---- OAuth providers ---------------------------------------------------
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ---- Google Pub/Sub push (Play RTDN webhook) ---------------------------
# The Google Play Real-time Developer Notifications webhook authenticates
# inbound Pub/Sub push deliveries by validating the OIDC Bearer token the
# Pub/Sub subscription signs each request with (see
# apps/api/src/middleware/webhook-verify.ts).
#
# PUBSUB_PUSH_AUDIENCE is the audience claim configured on the push
# subscription (typically the webhook URL, e.g.
# https://rovenue.io/v1/webhooks/google). REQUIRED in production — the
# webhook fails closed without it. When blank (local dev) the token
# verification is skipped.
#
# PUBSUB_PUSH_SERVICE_ACCOUNT optionally pins the expected signer email
# (the service account the subscription uses); leave blank to accept any
# valid Google-signed token for the audience.
PUBSUB_PUSH_AUDIENCE=
PUBSUB_PUSH_SERVICE_ACCOUNT=

# Bypass webhook signature verification. MUST be false (or unset) in
# production — the API startup rejects ALLOW_UNVERIFIED_WEBHOOKS=true
# when NODE_ENV=production. When true: Apple webhooks fall back to
# jose-only verification, Google webhooks skip Pub/Sub OIDC token
# validation. For local dev / integration tests only.
ALLOW_UNVERIFIED_WEBHOOKS=false

# ---- Kafka / Redpanda ---------------------------------------------------
# Comma-separated host:port list. docker-compose.yml exposes the
# external listener on localhost:19092; inside the compose network
# the api container talks to redpanda:9092 (set by compose env).
KAFKA_BROKERS=localhost:19092

# Gates the outbox→Kafka dispatcher. Default true. In docker-compose the
# dedicated `dispatcher` service forces this true and every other service
# (api + workers) forces it false, so this value is only used outside compose.
OUTBOX_DISPATCHER_ENABLED=true

# ---- Global edge cache (Cloudflare edge-cache Worker) ------------------
# Optional. When both are set, catalog mutations (offering/product) POST a
# per-project purge to the edge Worker so cached /v1/offerings responses are
# invalidated worldwide. Leave blank to disable (purge becomes a no-op).
# See deploy/cloudflare/edge-cache/README.md.
EDGE_CACHE_PURGE_URL=
EDGE_CACHE_PURGE_SECRET=

# ---- FX rates (OpenExchangeRates) --------------------------------------
# Free-tier app_id, USD-base + /latest only (~30 req/month from the
# daily cron). When blank the worker skips the fetch and convertToUsd
# falls through Redis → Postgres fx_rates → static fallback table.
# Sign up: https://openexchangerates.org/signup/free
OPEN_EXCHANGE_RATES_APP_ID=

# ---- Dashboard (Vite client) -------------------------------------------
# The dashboard image's build-time flags (VITE_HOST_MODE / VITE_ALLOW_REGISTRATION)
# are derived automatically from HOST_MODE / ALLOW_REGISTRATION above by
# docker-compose.yml's dashboard build args — set those once and both the API
# (runtime) and the dashboard bundle (build time) stay in sync. No separate
# VITE_* var is needed here.
#
# Only override directly when building the dashboard image OUTSIDE compose:
#   docker build --build-arg VITE_HOST_MODE=cloud --build-arg VITE_API_URL=...

# ---- Email transport ---------------------------------------------------
# EMAIL_PROVIDER selects the Mailer adapter:
#   - "resend" → RESEND_* below (default)
#   - "ses"    → AWS_SES_* below
#   - "smtp"   → SMTP_* below (self-hosted, no AWS creds required)
# EMAIL_FROM is the From: header used by every adapter. When unset on the
# SES path the older AWS_SES_FROM_EMAIL is consulted as a fallback. If
# "resend" is selected without RESEND_API_KEY, the mailer falls back to
# SES when a from address is configured.
EMAIL_PROVIDER=resend
EMAIL_FROM=

# ---- Resend (used when EMAIL_PROVIDER=resend) --------------------------
RESEND_API_KEY=
# Svix signing secret ("whsec_...") from the Resend dashboard webhook
# endpoint pointing at /webhooks/resend-events.
RESEND_WEBHOOK_SECRET=
RESEND_EVENTS_VERIFY_SIGNATURE=true

# ---- Amazon SES (used when EMAIL_PROVIDER=ses, or as resend fallback) --
AWS_SES_REGION=us-east-1
AWS_SES_FROM_EMAIL=
AWS_SES_CONFIGURATION_SET=
AWS_SES_EVENTS_VERIFY_SIGNATURE=true
# AWS credentials come from the default SDK provider chain:
#   AWS_ACCESS_KEY_ID + AWS_SECRET_ACCESS_KEY (env vars, dev/static)
#   or an IAM role attached to the host (recommended for prod).

# ---- Billing (Stripe) — cloud only -------------------------------------
# Active only when HOST_MODE=cloud. In production with HOST_MODE=cloud the
# secret key, webhook secret, and Indie monthly price id are required.
STRIPE_BILLING_SECRET_KEY=
STRIPE_BILLING_WEBHOOK_SECRET=
STRIPE_BILLING_PUBLISHABLE_KEY=
# Stripe Price IDs for platform billing. Required when HOST_MODE=cloud.
# Phase 2 only ships Indie/monthly; further tiers added in P4/P6.
STRIPE_BILLING_INDIE_MONTHLY_PRICE_ID=

# ---- Stripe Connect (customer Stripe accounts) -------------------------
# Independent of HOST_MODE — self-hosted installs register their own
# Connect platform (Stripe Dashboard -> Connect -> Settings) and fill
# these in. Leave blank to disable Stripe features entirely.
# In production, setting STRIPE_CONNECT_CLIENT_ID makes the platform
# secret key and Connect webhook secret mandatory.
STRIPE_CONNECT_CLIENT_ID=
STRIPE_CONNECT_CLIENT_ID_TEST=
STRIPE_PLATFORM_SECRET_KEY=
STRIPE_PLATFORM_SECRET_KEY_TEST=
STRIPE_PLATFORM_PUBLISHABLE_KEY=
STRIPE_PLATFORM_PUBLISHABLE_KEY_TEST=
# Signing secret of the platform webhook endpoint that has
# "listen to Connect events" enabled.
STRIPE_CONNECT_WEBHOOK_SECRET=

# ---- Funnel paywall serving domain (Apple Pay) -------------------------
# The host a published funnel paywall page is served from. On connect,
# this host is registered as a payment method domain on the customer's
# connected account; without it Stripe never offers Apple Pay on the
# funnel paywall (the card form still works, so it fails silently).
# Bare hostname only — no scheme, port, path or trailing dot.
# Production: FUNNEL_PAYMENT_DOMAIN=app.rovenue.io  (serves /f/<slug>)
# Leave blank to skip registration entirely. Do NOT guess: registering a
# host that does not serve the page is worse than not registering.
# The host must also serve Stripe's verification file — see
# docs/operations/deployment.md "Apple Pay on funnel paywalls".
FUNNEL_PAYMENT_DOMAIN=

# ---- SMTP (used when EMAIL_PROVIDER=smtp) ------------------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
# true for implicit TLS (port 465); false for STARTTLS (port 587).
SMTP_SECURE=false

# ---- Unsubscribe-link signing ------------------------------------------
# 32-byte hex key (64 chars) used to HMAC-SHA256 the one-click
# unsubscribe links embedded in outgoing notification email headers.
# Required in production. Generate with: openssl rand -hex 32
UNSUB_SIGNING_KEY=

# ---- Apple Root Certificates (StoreKit JWS verification) ---------------
# Host directory holding Apple Root CA .cer files (Apple Root CA G3 +
# Apple Inc Root). Mounted read-only into the api at
# /etc/rovenue/apple-certs. REQUIRED in production — the StoreKit JWS
# verifier fails closed when missing.
APPLE_ROOT_CERTS_HOST_DIR=./deploy/apple-certs
APPLE_ROOT_CERTS_DIR=/etc/rovenue/apple-certs

# ---- Apple Push Notification service (optional; enables iOS push) ------
# Token-based auth. APNS_KEY_P8 is the contents of the AuthKey_*.p8 file
# verbatim (BEGIN/END lines included). APNS_ENVIRONMENT selects the
# production gateway (api.push.apple.com) or the sandbox host that
# TestFlight builds talk to (api.sandbox.push.apple.com).
APNS_KEY_ID=
APNS_TEAM_ID=
APNS_KEY_P8=
APNS_BUNDLE_ID=
APNS_ENVIRONMENT=production

# ---- Firebase Cloud Messaging (optional; enables Android push) --------
# Service-account JSON pasted verbatim into the env var.
FCM_SERVICE_ACCOUNT_JSON=

# ---- Rovi (AI copilot) ------------------------------------------------
# Tier quotas apply only when HOST_MODE=cloud; self-host is unlimited and
# uses bring-your-own provider keys (set per project in the dashboard).
# ROVI_TIER sets the cloud default tier when projects.metadata has no
# rovi_tier override.
# ROVI_TIER=free|team|business|enterprise
ROVI_RATE_LIMIT_PER_USER=30
ROVI_MESSAGE_RETENTION_DAYS=90
# Optional operator-funded fallback when a project has no BYOK credentials.
# ROVI_DEFAULT_PROVIDER=openai
# ROVI_DEFAULT_MODEL=gpt-4o-mini
# ROVI_DEFAULT_API_KEY=
# ROVI_DEFAULT_BASE_URL=https://api.openai.com/v1

# --- Observability (optional; only used with COMPOSE_PROFILES=observability) ---
# METRICS_ENABLED toggles prom-client instrumentation in the API (RED metrics +
# internal /metrics listener). Set false to opt out even within the profile.
METRICS_ENABLED=true
GRAFANA_ADMIN_USER=admin
# WARNING: If left blank, the Grafana admin password defaults to "admin".
# This MUST be set to a strong value before exposing Grafana to the internet
# or any shared/production environment. Generate with: openssl rand -base64 24
GRAFANA_ADMIN_PASSWORD=
PROMETHEUS_RETENTION=15d
